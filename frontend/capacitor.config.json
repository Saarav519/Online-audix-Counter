{
  "appId": "com.audix.stockmanagement",
  "appName": "Audix",
  "webDir": "build",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#10b981",
      "showSpinner": false,
      "androidSpinnerStyle": "small"
    }
  }
}
